# Copy to .env and fill in. This file (and the whole ai-grants/ dir) is gitignored.
# notify.py auto-loads .env via grants_lib. Skipped channels just print a notice.

# ── Telegram group posting ──────────────────────────────────────────────
# 1. Message @BotFather -> /newbot -> copy the token here.
# 2. Add the bot to your group and make it an admin (so it can post).
# 3. Get the group chat id (a negative number): add @getidsbot to the group,
#    or send a message and read it from api.telegram.org/bot<token>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Email (SMTP) ────────────────────────────────────────────────────────
# For Gmail: enable 2FA, then create an App Password (not your login password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=account1@liminalcommons.com
SMTP_PASS=
REPORT_EMAIL_TO=account1@liminalcommons.com
REPORT_EMAIL_FROM=account1@liminalcommons.com
